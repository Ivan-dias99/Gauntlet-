# Signal backend — environment variables
# Copy to .env and fill in your Anthropic API key.

# REQUIRED — Anthropic API key (or set SIGNAL_MOCK=1 below to bypass it).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server binding.
SIGNAL_HOST=127.0.0.1
SIGNAL_PORT=3002

# CORS origins — comma-separated list. Localhost dev origins are appended
# automatically by server.py. In prod, set this to the Vercel domain only.
SIGNAL_ORIGIN=http://localhost:5173

# Persistent state directory (signal.db lives here). MUST be a mounted
# volume in production — otherwise restarts wipe the archive.
# SIGNAL_DATA_DIR=/data

# Code-execution gate. When false, the gated tool set (run_command, execute_python)
# refuses invocation regardless of the chamber profile.
SIGNAL_ALLOW_CODE_EXEC=false

# Offline pipeline — bypasses Anthropic with canned responses. Useful for
# CI, smoke tests, and end-to-end validation without a key.
# SIGNAL_MOCK=1
