{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gauntlet",
  "version": "1.0.1",
  "identifier": "dev.gauntlet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5179",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gauntlet",
        "url": "index.html",
        "width": 720,
        "height": 480,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": false,
        "visible": false,
        "skipTaskbar": true,
        "focus": true
      },
      {
        "label": "pill",
        "title": "Gauntlet pill",
        "url": "pill.html",
        "width": 220,
        "height": 56,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": false,
        "visible": false,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:3002 http://localhost:3002 https://ruberra-backend-jkpf-production.up.railway.app; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; worker-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32.png",
      "icons/128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Ivan-dias99/Gauntlet-/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwRTQ0NzY5N0JCNTQ1NjcKUldSblJiVjdhVWZrRU1tay9ibjlVNkRKa3gwcGx3MGp2M0Y4VUJYdkpsUnFDT0E5TWc3eXl4ZE0K"
    }
  }
}
