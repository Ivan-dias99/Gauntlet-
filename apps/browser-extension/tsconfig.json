{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@gauntlet/composer": ["../../packages/composer/src/index.ts"],
      "@gauntlet/composer/*": ["../../packages/composer/src/*"]
    }
  },
  "include": [
    "entrypoints/**/*",
    "components/**/*",
    "lib/**/*",
    "wxt.config.ts",
    "../../packages/composer/src/**/*"
  ]
}
