{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "Bundler"
  },
  "include": [
    "entrypoints/**/*",
    "components/**/*",
    "lib/**/*",
    "ambient/**/*",
    "wxt.config.ts"
  ]
}
