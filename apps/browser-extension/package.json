{
  "name": "@gauntlet/browser-extension",
  "description": "Gauntlet — cursor capsule for the browser (Manifest V3, WXT).",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "build:zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.6.2",
    "wxt": "^0.19.13"
  }
}
