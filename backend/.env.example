# Gauntlet — .env Template
# Provider precedence (engine.py): MOCK > Groq > Anthropic > Gemini > error.
# Copia para .env e descomenta UMA das opções abaixo.

# REQUIRED — escolhe um provider:
#   1. Groq (PRIMÁRIO, free tier — Llama 3.x, RPM/RPD generosos)
#      Get a key at https://console.groq.com/keys
GAUNTLET_GROQ_API_KEY=
GAUNTLET_GROQ_MODEL=llama-3.3-70b-versatile

#   2. Anthropic Claude (PAUSADO — só usar se Groq não for opção)
#      Custo / falta de créditos motivou pausa em 2026-05-08.
#ANTHROPIC_API_KEY=sk-ant-your-key-here

#   3. Google Gemini (PAUSADO — segundo fallback opcional)
#      Get a key at https://aistudio.google.com/apikey
#GAUNTLET_GEMINI_API_KEY=

#   4. Modo offline — respostas canned, sem chamadas à rede. Útil para
#      smoke / desenvolvimento sem chave de provider.
#GAUNTLET_MOCK=1

# Server configuration (optional)
GAUNTLET_HOST=127.0.0.1
GAUNTLET_PORT=3002
GAUNTLET_ORIGIN=http://localhost:5173
GAUNTLET_ULTRA_PARANOIA=false

# SIGNAL_* and RUBERRA_* are still read as silent fallbacks during the
# transition window — see docs/OPERATIONS.md for the full alias table.
