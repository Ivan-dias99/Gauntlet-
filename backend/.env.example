# Gauntlet — .env Template
# Copy to .env and set ONE provider key (Anthropic OR Gemini).

# REQUIRED — pick one provider:
#   1. Anthropic Claude (paid) — primary path
ANTHROPIC_API_KEY=sk-ant-your-key-here
#   2. Google Gemini (free tier) — used when ANTHROPIC_API_KEY is empty.
#      Get a key at https://aistudio.google.com/apikey
GAUNTLET_GEMINI_API_KEY=

# Server configuration (optional)
GAUNTLET_HOST=127.0.0.1
GAUNTLET_PORT=3002
GAUNTLET_ORIGIN=http://localhost:5173
GAUNTLET_ULTRA_PARANOIA=false

# SIGNAL_* and RUBERRA_* are still read as silent fallbacks during the
# transition window — see docs/OPERATIONS.md for the full alias table.
