{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Read(./**)",

      "Bash(npm test:*)",
      "Bash(npm run check:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npm install)",
      "Bash(npm ci)",

      "Bash(pnpm test:*)",
      "Bash(pnpm run check:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm install)",

      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m mypy:*)",
      "Bash(python -m ruff:*)",
      "Bash(uv run:*)",
      "Bash(uv sync)",

      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",

      "Bash(playwright test:*)",
      "Bash(npx playwright:*)",
      "Bash(vitest:*)",
      "Bash(npx vitest:*)",

      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git fetch)",
      "Bash(git pull)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh release list)",
      "Bash(gh release view:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(stat:*)",

      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod +x:*)",

      "Bash(jq:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(date:*)",
      "Bash(test:*)"
    ],

    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r /:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin :*)",
      "Bash(git reset --hard:*)",
      "Bash(git filter-branch:*)",
      "Bash(git clean -fdx:*)",

      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(cargo publish:*)",
      "Bash(twine upload:*)",

      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",

      "Bash(chmod 777:*)",
      "Bash(chown:*)",

      "Bash(docker system prune:*)",
      "Bash(docker rm -f:*)"
    ]
  },

  "env": {
    "GAUNTLET_MOCK": "0",
    "GAUNTLET_TELEMETRY_DISABLED": "0",
    "TAURI_DEV_HOST": "localhost",
    "RAILWAY_DEPLOY_BLOCKED": "false"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -s .claude/memory.log ]; then printf '=== last 10 memory entries ===\\n'; tail -n 10 .claude/memory.log; else echo '(memory log empty)'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date -Iseconds)\" '\"[\\($ts)] \\(.tool_name): \\(.tool_input | tostring | .[0:200])\"' >> .claude/memory.log 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit.sh || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ]
  }
}
