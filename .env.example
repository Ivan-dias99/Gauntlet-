# Gauntlet — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ── Anthropic ───────────────────────────────────────────────────────────────
# Consumed by the Python backend. Set this in Railway, not in the frontend .env.
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (free-tier fallback, preferred over Gemini) ───────────────────────
# When ANTHROPIC_API_KEY is empty, the engine falls back to Groq if this is
# set. Triad + judge work; agent loop / streaming are NOT supported on this
# path (v1 adapter scope — text-only).
# Get a key at https://console.groq.com (free tier, no credit card).
# GAUNTLET_GROQ_API_KEY=gsk_...
# GAUNTLET_GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini (free-tier fallback) ────────────────────────────────────────────
# Used when both ANTHROPIC_API_KEY and GAUNTLET_GROQ_API_KEY are empty.
# Same scope limitation as Groq: text-only, no agent loop / streaming.
# GAUNTLET_GEMINI_API_KEY=...
# GAUNTLET_GEMINI_MODEL=gemini-2.5-flash

# ── Backend bridge ──────────────────────────────────────────────────────────
# Python backend (backend/ on disk after the Gauntlet migration) — FastAPI.
#
# Dev  : vite.config.ts proxies /api/gauntlet/* (and legacy /api/signal/*,
#        /api/ruberra/*) to this URL.
# Prod : api/gauntlet.ts (Vercel edge, flat file + rewrite in vercel.json)
#        forwards /api/gauntlet/* to this URL. api/signal.ts and
#        api/ruberra.ts are kept as legacy aliases.
#        Set GAUNTLET_BACKEND_URL in the Vercel project env.
GAUNTLET_BACKEND_URL=http://127.0.0.1:3002

# Legacy aliases — read as fallbacks when GAUNTLET_BACKEND_URL is unset.
# Drop these once the canonical name lands in every deployed env.
# SIGNAL_BACKEND_URL=http://127.0.0.1:3002
# RUBERRA_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (config.py).
# On Railway: GAUNTLET_HOST=0.0.0.0 and PORT is provided automatically.
GAUNTLET_HOST=127.0.0.1
GAUNTLET_PORT=3002

# CORS — comma-separated list of allowed origins. Localhost dev origins are
# appended automatically. In prod set this to the Vercel domain(s) only.
GAUNTLET_ORIGIN=http://localhost:5173

# Agent tool execution gate (tools.py).
# Controls whether run_command can invoke package managers and interpreters:
# pip, pip3, npm, npx, node. Default is off — set to true only in trusted envs.
# execute_python is gated by this same variable.
GAUNTLET_ALLOW_CODE_EXEC=false

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Override the base URL used by the React app to reach the backend. Leave
# unset for same-origin deploys (the Vercel edge forwarder handles bridging).
# VITE_GAUNTLET_API_BASE=https://gauntlet-backend.up.railway.app
#
# Legacy aliases — honored as fallbacks when VITE_GAUNTLET_API_BASE is unset.
# VITE_SIGNAL_API_BASE=https://gauntlet-backend.up.railway.app
# VITE_RUBERRA_API_BASE=https://gauntlet-backend.up.railway.app
