# Signal — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ── Anthropic ───────────────────────────────────────────────────────────────
# Consumed by the Python backend. Set on the backend host (Railway), not the
# frontend.
ANTHROPIC_API_KEY=sk-ant-...

# ── Backend bridge ──────────────────────────────────────────────────────────
# Python backend (signal-backend/) — FastAPI.
#
# Dev  : vite.config.ts proxies /api/signal/* to this URL.
# Prod : api/signal.ts (Vercel edge) forwards /api/signal/* to this URL via
#        the rewrite in vercel.json. Set SIGNAL_BACKEND_URL in the Vercel
#        project env to the Railway public domain (e.g.
#        https://signal-backend.up.railway.app).
SIGNAL_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (config.py).
# On Railway: SIGNAL_HOST=0.0.0.0 and PORT is provided automatically.
SIGNAL_HOST=127.0.0.1
SIGNAL_PORT=3002

# CORS — comma-separated list of allowed origins. Localhost dev origins are
# appended automatically. In prod set this to the Vercel domain(s) only.
# Example: SIGNAL_ORIGIN=https://signal.vercel.app,https://www.signal.app
SIGNAL_ORIGIN=http://localhost:5173

# Persistent state directory (failures, runs, spine, sqlite). MUST be a
# mounted volume in production. Default ${signal-backend}/data.
# SIGNAL_DATA_DIR=/data

# Agent tool execution gate (tools.py).
# Controls whether run_command can invoke package managers and interpreters
# (pip, pip3, npm, npx, node) and whether execute_python is enabled.
# Default false — set to true only in trusted environments.
SIGNAL_ALLOW_CODE_EXEC=false

# Offline pipeline — bypasses Anthropic with canned responses.
# SIGNAL_MOCK=1

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Override the base URL used by the React app to reach the backend. Leave
# unset for same-origin deploys (the Vercel edge forwarder handles bridging).
# Only set when the frontend must call the backend directly.
# VITE_SIGNAL_API_BASE=https://signal-backend.up.railway.app
