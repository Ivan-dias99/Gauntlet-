# Ruberra environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Supabase project credentials (required for Supabase-backed features)
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Canonical Python backend (apps/backend/rubeira_backend).
# Used by src/ruberra/spine/backendClient.ts for /route and /dev.
VITE_BACKEND_URL=http://localhost:8000
