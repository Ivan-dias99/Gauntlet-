# Ruberra environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Supabase project credentials (required for Supabase-backed features)
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Ruberra execution backend URL (optional, enables real execution)
# Default: leave unset to run in unbound mode
VITE_RUBERRA_EXEC_URL=http://localhost:3001

# Exec backend configuration (used by exec-backend/index.mjs)
RUBERRA_EXEC_PORT=3001
RUBERRA_ORIGIN=http://localhost:5173
