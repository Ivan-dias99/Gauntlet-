# Ruberra — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# Anthropic API key — consumed by the Python backend (ruberra-backend/).
ANTHROPIC_API_KEY=sk-ant-...

# Python backend (ruberra-backend/) — FastAPI on 127.0.0.1:3002 by default.
# In dev: vite.config.ts proxies /api/ruberra/* to this URL.
# In prod: api/ruberra/[...path].ts (Vercel edge) forwards /api/ruberra/* to this URL.
RUBERRA_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (consumed by ruberra-backend/config.py).
RUBERRA_HOST=127.0.0.1
RUBERRA_PORT=3002
RUBERRA_ORIGIN=http://localhost:5173

# Agent tool execution gate (ruberra-backend/tools.py).
# Controls whether run_command can invoke package managers and interpreters:
# pip, pip3, npm, npx, node. Default is off — set to true only in trusted envs.
# execute_python is gated by this same variable.
RUBERRA_ALLOW_CODE_EXEC=false
