# Ruberra — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# Anthropic API key — required by both the edge chat endpoint and the
# Python backend (rubeira-backend/).
ANTHROPIC_API_KEY=sk-ant-...

# Python backend (rubeira-backend/) — FastAPI on 127.0.0.1:3002 by default.
# In dev, vite.config.ts proxies /api/* to this URL.
# In prod, set this to the public URL of your deployed FastAPI instance
# and api/chat.ts will forward to it.
RUBEIRA_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (consumed by rubeira-backend/config.py).
RUBEIRA_HOST=127.0.0.1
RUBEIRA_PORT=3002
RUBEIRA_ORIGIN=http://localhost:5173
