# Ruberra — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ── Anthropic ───────────────────────────────────────────────────────────────
# Consumed by the Python backend (ruberra-backend/). Set this in Railway,
# not in the frontend .env.
ANTHROPIC_API_KEY=sk-ant-...

# ── Backend bridge ──────────────────────────────────────────────────────────
# Python backend (ruberra-backend/) — FastAPI.
#
# Dev  : vite.config.ts proxies /api/ruberra/* to this URL.
# Prod : api/ruberra.ts (Vercel edge, flat file + rewrite in vercel.json)
#        forwards /api/ruberra/* to this URL. Set RUBERRA_BACKEND_URL in
#        the Vercel project env
#        to the Railway public domain
#        (e.g. https://ruberra-backend.up.railway.app).
RUBERRA_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (ruberra-backend/config.py).
# On Railway: RUBERRA_HOST=0.0.0.0 and PORT is provided automatically.
RUBERRA_HOST=127.0.0.1
RUBERRA_PORT=3002

# CORS — comma-separated list of allowed origins. Localhost dev origins are
# appended automatically. In prod set this to the Vercel domain(s) only.
# Example: RUBERRA_ORIGIN=https://ruberra.vercel.app,https://www.ruberra.app
RUBERRA_ORIGIN=http://localhost:5173

# Agent tool execution gate (ruberra-backend/tools.py).
# Controls whether run_command can invoke package managers and interpreters:
# pip, pip3, npm, npx, node. Default is off — set to true only in trusted envs.
# execute_python is gated by this same variable.
RUBERRA_ALLOW_CODE_EXEC=false

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Override the base URL used by the React app to reach the backend. Leave
# unset for same-origin deploys (Vercel edge forwarder handles bridging).
# Only set when the frontend must call the backend directly.
# VITE_RUBERRA_API_BASE=https://ruberra-backend.up.railway.app
