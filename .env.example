# Signal — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ── Anthropic ───────────────────────────────────────────────────────────────
# Consumed by the Python backend. Set this in Railway, not in the frontend .env.
ANTHROPIC_API_KEY=sk-ant-...

# ── Backend bridge ──────────────────────────────────────────────────────────
# Python backend (ruberra-backend/ on disk until Wave 8) — FastAPI.
#
# Dev  : vite.config.ts proxies /api/signal/* (and legacy /api/ruberra/*)
#        to this URL.
# Prod : api/signal.ts (Vercel edge, flat file + rewrite in vercel.json)
#        forwards /api/signal/* to this URL. api/ruberra.ts is kept as a
#        legacy alias during the Wave-0 → Wave-8 compatibility window.
#        Set SIGNAL_BACKEND_URL in the Vercel project env to the Railway
#        public domain (e.g. https://signal-backend.up.railway.app).
SIGNAL_BACKEND_URL=http://127.0.0.1:3002

# Legacy alias — still read as a fallback if SIGNAL_BACKEND_URL is unset.
# Kept to avoid breaking existing deployments during compat. Removed in
# Wave 8. Do not set both; if both are present, SIGNAL_BACKEND_URL wins.
# RUBERRA_BACKEND_URL=http://127.0.0.1:3002

# Python backend binding (config.py).
# On Railway: RUBERRA_HOST=0.0.0.0 and PORT is provided automatically.
RUBERRA_HOST=127.0.0.1
RUBERRA_PORT=3002

# CORS — comma-separated list of allowed origins. Localhost dev origins are
# appended automatically. In prod set this to the Vercel domain(s) only.
# Example: RUBERRA_ORIGIN=https://signal.vercel.app,https://www.signal.app
RUBERRA_ORIGIN=http://localhost:5173

# Agent tool execution gate (tools.py).
# Controls whether run_command can invoke package managers and interpreters:
# pip, pip3, npm, npx, node. Default is off — set to true only in trusted envs.
# execute_python is gated by this same variable.
RUBERRA_ALLOW_CODE_EXEC=false

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Override the base URL used by the React app to reach the backend. Leave
# unset for same-origin deploys (the Vercel edge forwarder handles bridging).
# Only set when the frontend must call the backend directly.
# VITE_SIGNAL_API_BASE=https://signal-backend.up.railway.app
#
# Legacy alias — honored as a fallback when VITE_SIGNAL_API_BASE is unset.
# Removed in Wave 8.
# VITE_RUBERRA_API_BASE=https://signal-backend.up.railway.app
