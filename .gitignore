node_modules/
dist/
dist-ssr/
# WXT build output — regenerated by `npm run build` in
# apps/browser-extension. `release/unpacked/` is the canonical
# pre-built artefact for "Load unpacked" users without Node.
.output/
*.local
.env
.env.*
!.env.example
.env*.local
.DS_Store
.vercel
test-results/
playwright-report/
ops/CODEX_LOOP_STATE.json
ops/CODEX_LOOP_STATE.log

# Transient build artifacts at root — outputs, not sources
build_*.log
build_*.txt

# Browser-extension pre-built side-load zip. Regenerated by
# `npm run zip` in apps/browser-extension/. Do not commit — release
# bundles ship as GitHub release artefacts via .github/workflows/release.yml.
scripts/gauntlet-edge.zip

# Python bytecode
__pycache__/
*.pyc

# Claude Code session memory log (populated by SessionStart/PostToolUse hooks)
.claude/memory.log
**/.claude/memory.log

# Parallel-agent isolated worktrees (Agent tool with isolation:"worktree").
# Created at runtime under .claude/worktrees/agent-<id>; never source.
.claude/worktrees/

# Gauntlet backend runtime data (failure memory, runs log, spine snapshot).
# Canonical is backend/data/. Legacy paths (signal-backend/, ruberra-backend/)
# are kept ignored only to protect dev machines that still have those folders
# from a pre-rename checkout. Drop them in v1.1.0.
backend/data/
data/
signal-backend/data/
ruberra-backend/data/
